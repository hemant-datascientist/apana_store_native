{
  "expo": {
    "name": "Apana Store",
    "slug": "apana_store_native",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "apanastore",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.apana.store.customer"
    },
    "android": {
      "package": "com.apana.store.customer",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F4C81",
          "dark": {
            "backgroundColor": "#0A1628"
          }
        }
      ],
      "expo-font",
      "expo-camera",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Apana Store to use your location to show nearby stores and get accurate delivery times.",
          "locationAlwaysAndWhenInUsePermission": "Allow Apana Store to use your location to show nearby stores and get accurate delivery times."
        }
      ],
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "extraMavenRepos": [
              "https://maven.mappls.com/repository/mappls/"
            ]
          }
        }
      ],
      [
        "./plugins/withMappls",
        {
          "confPath": "./assets/mappls/mappls.a.conf",
          "olfPath": "./assets/mappls/mappls.a.olf"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
