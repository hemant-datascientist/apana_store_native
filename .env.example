# =============================================================================
# Apana Store (Customer App) — Environment Template
# =============================================================================
# Copy to .env and fill values. Expo bakes EXPO_PUBLIC_* vars at build time.
# Never commit .env — only .env.example tracked.
# =============================================================================

# ---- Backend selection ----
# mock  : Prism mock server (apana-contracts/  npm run mock:customer)
# local : Backend running on Tower or Win uvicorn (uses EXPO_PUBLIC_TOWER_IP)
# prod  : https://api.apana.in
EXPO_PUBLIC_API_MODE=mock

# Tower LAN IP — only used when EXPO_PUBLIC_API_MODE=local
EXPO_PUBLIC_TOWER_IP=192.168.1.50

# ---- Mappls (REAL — already in use by services/mapplsService.ts) ----
EXPO_PUBLIC_MAPPLS_REST_KEY=
EXPO_PUBLIC_MAPPLS_CLIENT_ID=
